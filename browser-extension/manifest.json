{
  "manifest_version": 3,
  "name": "NoteOne Capture",
  "version": "1.0",
  "description": "一键捕获网页链接、选中文本和媒体到 NoteOne 笔记",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "scripting", "storage", "contextMenus"],
  "host_permissions": ["http://localhost:3000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "NoteOne Capture"
  },
  "commands": {
    "capture-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "捕获当前页面到 NoteOne"
    }
  }
}
