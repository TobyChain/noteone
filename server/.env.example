# NoteOne server environment — copy to .env and fill in.

# Runtime mode: development | production
NODE_ENV=development
PORT=3000

# Postgres (pgvector) connection string — REQUIRED
DATABASE_URL=postgres://noteone:noteone@localhost:5432/noteone

# JWT signing secret — REQUIRED. Use a long random value (>= 16 chars).
# In production the server refuses to start with a weak/default secret.
JWT_SECRET=

# Apple Sign-In: the audience(s) the identityToken must be issued for.
# Comma-separated bundle ids. Defaults to com.noteone.app.
APPLE_CLIENT_IDS=com.noteone.app

# CORS allow-list (comma-separated origins). Empty => reflect request origin (dev only).
ALLOWED_ORIGINS=

# Set to "true" to enable the /auth/dev-token endpoint. Never effective in production.
ENABLE_DEV_LOGIN=false

# LLM provider (Qwen-compatible OpenAI API)
QWEN_API_KEY=your-qwen-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
