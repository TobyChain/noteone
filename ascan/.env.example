# Ascan 环境变量配置
# 复制此文件为 .env 并填入真实值：cp .env.example .env
# 所有配置项均对应 src/config/settings.py 中的 pydantic Field
#
# 注意：pydantic-settings 不支持行内注释，值后面不能写 # 注释

# ========== LLM 配置（必填）==========
# IdealAb OpenAI 兼容 API，用于论文摘要翻译和 GitHub 仓库深度分析
IDEALAB_API_KEY=""
IDEALAB_BASE_URL="https://idealab.alibaba-inc.com/api/openai/v1"
LLM_MODEL="Qwen3.6-Plus-DogFooding"
# 单次请求超时（秒），默认 120
# LLM_TIMEOUT=120
# 最大重试次数，默认 3
# LLM_MAX_RETRIES=3

# ========== GitHub Agent 配置 ==========
# GitHub Personal Access Token（需要 public_repo read scope）
GITHUB_TOKEN=""
# 追踪的 GitHub topic 列表（逗号分隔）
# GITHUB_TOPICS="digital-twin,digital-avatar,recommendation-system,product-recommendation,e-commerce,product-inspection,compliance-detection,content-moderation,customer-service,chatbot,conversational-ai,llm-agent,ai-agent,rag,multi-agent"
# 每个 topic 最多抓取仓库数，默认 8
# GITHUB_MAX_REPOS_PER_TOPIC=8
# 最低 star 数过滤，默认 500
# GITHUB_MIN_STARS=500
# 送入 LLM 深度分析的 Top N 仓库，默认 20
# GITHUB_TOP_ANALYZE=20

# ========== ArXiv 配置 ==========
# 要抓取的 arXiv 分类（JSON 数组或逗号分隔）
ARXIV_SUBJECTS=["cs.AI","cs.IR","cs.CL","cs.MA","cs.CV"]
# 日期偏移天数（默认 1 = 昨天）
# ARXIV_DATE_OFFSET_DAYS=1
# 每个分类最大论文数，默认 200
# MAX_PAPERS_PER_SUBJECT=200
# 总最大论文数，默认 500
# MAX_TOTAL_PAPERS=500

# ========== 钉钉知识库上传（可选）==========
# 配置后 pipeline 结束会提示执行 /upload-ascan 手动上传
# 知识库空间 ID（从 URL 获取，如 https://alidocs.dingtalk.com/i/spaces/xxx 中的 xxx）
# DINGTALK_WORKSPACE_ID=""
# 上传到哪个文件夹（父节点 UUID）
# DINGTALK_PARENT_NODE_ID=""

# ========== 应用配置 ==========
# HTML 日报输出目录，默认 ./docs
# OUTPUT_DIR=./docs
# 数据库连接，默认 SQLite
# DATABASE_URL=sqlite:///./database/arxiv_papers.db
# 日志级别：DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO

# ========== 会议论文追踪（可选）==========
# Semantic Scholar API Key（免费申请: https://www.semanticscholar.org/product/api#api-key-form）
# SEMANTIC_SCHOLAR_API_KEY=""
# 会议论文回溯天数（滑动窗口），默认 30
# CONFERENCE_LOOKBACK_DAYS=30
# 追踪的会议等级（逗号分隔），默认 A,B
# CONFERENCE_RANK_FILTER=A,B
# 追踪的会议方向分类，默认 ai,nlp,cv,dm,ir
# CONFERENCE_CATEGORIES=ai,nlp,cv,dm,ir
